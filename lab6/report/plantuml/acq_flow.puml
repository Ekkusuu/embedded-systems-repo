@startuml
skinparam monochrome true
skinparam shadowing false

start
:Read Pot A1;
:Update Thigh/Tlow;
:ntc.readSample();
:buzzer.setAlert(false);
:dht.readSample();
:ntcFilter.update(Tntc);
if (dht valid?) then (yes)
  :dhtFilter.update(Tdht);
endif
:systemAlert = ntcStable or dhtStable;
:leds.setAlert(systemAlert);
:buzzer.setAlert(systemAlert);
stop
@enduml
